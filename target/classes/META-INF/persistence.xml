<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

  <persistence-unit name="ProyectoWebPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

    <class>com.proyectoweb.modelo.entities.Usuario</class>
    <class>com.proyectoweb.modelo.entities.Categoria</class>
    <class>com.proyectoweb.modelo.entities.PreferenciaUsuario</class>
    <class>com.proyectoweb.modelo.entities.ElementoContenido</class>
    <class>com.proyectoweb.modelo.entities.LugarTuristico</class>
    <class>com.proyectoweb.modelo.entities.EstablecimientoGastronomico</class>
    <class>com.proyectoweb.modelo.entities.Evento</class>
    <class>com.proyectoweb.modelo.entities.Evaluacion</class>
    <class>com.proyectoweb.modelo.entities.Favorito</class>

    <properties>
      <!-- Ajusta host, puerto, nombre de BD, usuario y contraseña -->
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/proyectoweb_db?useSSL=false&amp;serverTimezone=UTC&amp;useUnicode=true&amp;characterEncoding=UTF-8"/>
      <property name="jakarta.persistence.jdbc.user" value="root"/>
      <property name="jakarta.persistence.jdbc.password" value=""/>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

      <!-- Borra y crea las tablas en desarrollo; luego carga datos de prueba. -->
      <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
      <property name="jakarta.persistence.schema-generation.create-source" value="metadata"/>
      <property name="jakarta.persistence.schema-generation.drop-source" value="metadata"/>
      <property name="jakarta.persistence.sql-load-script-source" value="META-INF/sql/datos_prueba.sql"/>

      <property name="eclipselink.logging.level" value="FINE"/>
    </properties>
  </persistence-unit>
</persistence>
